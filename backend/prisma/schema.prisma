generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  nama      String
  username  String    @unique
  password  String
  namaPena  String
  bio       String    @default("")
  role      String    @default("penulis")
  banned    Boolean   @default(false)
  createdAt DateTime  @default(now())

  posts     Post[]
  comments  Comment[]
  likes     Like[]
}

model Post {
  id            String    @id @default(cuid())
  judul         String
  tipe          String    @default("cerpen")
  isi           String    @default("")
  isiHtml       String    @default("")
  status        String    @default("draft")
  catatanAdmin  String    @default("")
  kategori      String    @default("Umum")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // onDelete: Cascade -> kalau User dihapus, semua Post miliknya ikut terhapus otomatis
  penulis       User      @relation(fields: [penulisId], references: [id], onDelete: Cascade)
  penulisId     String

  comments      Comment[]
  likes         Like[]
}

model Comment {
  id        String   @id @default(cuid())
  isi       String
  createdAt DateTime @default(now())

  // onDelete: Cascade -> kalau Post/User dihapus, komentar terkait ikut terhapus otomatis
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model Like {
  id     String @id @default(cuid())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([postId, userId])
}
